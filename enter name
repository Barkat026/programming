from tkinter import *
root = Tk()

def submit_button():
    x = e1.get()


    l2.config(text="result"+x)

root.geometry("500x500")

l1 = Label(root,text="enter your name ")
l1.place(x=100,y =100)

e1 = Entry(root)
e1.place(x=200,y =100)

b1 = Button(root,text="Submit",command=submit_button)
b1.place(x=130,y=150)

l2 = Label(root)
l2.place(x=90,y=200)
root.mainloop()
